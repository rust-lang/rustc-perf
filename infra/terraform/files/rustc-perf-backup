#!/bin/bash
# pipefail matters: the tar | aws s3 cp upload below must fail when tar fails,
# otherwise a truncated archive would be promoted to latest.tar.gz.
set -euo pipefail

host_env_file="/etc/rustc-perf-site.host.env"
if [ -f "$host_env_file" ]; then
  set -a
  . "$host_env_file"
  set +a
fi

# The host env file written by Terraform is the single source of truth for
# these; fail loudly instead of falling back to defaults that could drift.
backup_bucket="${RUSTC_PERF_BACKUP_BUCKET:?RUSTC_PERF_BACKUP_BUCKET is not set}"
data_root="${RUSTC_PERF_DATA_DIR:?RUSTC_PERF_DATA_DIR is not set}"
db_name="${RUSTC_PERF_DB_FILENAME:?RUSTC_PERF_DB_FILENAME is not set}"
state_root="${data_root}/.state"
image_ref="${RUSTC_PERF_IMAGE_REF:?RUSTC_PERF_IMAGE_REF is not set}"
backup_prefix="${RUSTC_PERF_BACKUP_PREFIX:?RUSTC_PERF_BACKUP_PREFIX is not set}"
archive_dir="${RUSTC_PERF_BACKUP_ARCHIVE_DIR:?RUSTC_PERF_BACKUP_ARCHIVE_DIR is not set}"
latest_name="${RUSTC_PERF_BACKUP_LATEST_NAME:?RUSTC_PERF_BACKUP_LATEST_NAME is not set}"
caddy_data_dir="${RUSTC_PERF_CADDY_DATA_DIR:?RUSTC_PERF_CADDY_DATA_DIR is not set}"
staging_root="/var/lib/rustc-perf-backup-staging"
lock_file="/var/lock/rustc-perf-backup.lock"
timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
host_name="$(hostname -s)"
snapshot_dir=""

cleanup() {
  [ -n "$snapshot_dir" ] && rm -rf "$snapshot_dir"
}

trap cleanup EXIT INT TERM

exec 9>"$lock_file"
flock -n 9

if [ ! -s "${data_root}/${db_name}" ]; then
  echo "Missing database at ${data_root}/${db_name}" >&2
  exit 1
fi

install -d -m 700 "$staging_root"
snapshot_dir="$(mktemp -d "$staging_root/${timestamp}.XXXXXX")"

# Consistent online snapshot without stopping the service. In WAL mode the
# SQLite backup API cooperates with the live writer and produces a single,
# already checkpointed database file, so the -wal/-shm sidecars are not needed.
# The .timeout (in ms: 30s, same as the app's busy_timeout in
# database/src/pool/sqlite.rs) keeps the backup from failing with SQLITE_BUSY
# when it fires while the orchestrator holds a write transaction.
sqlite3 -cmd ".timeout 30000" "${data_root}/${db_name}" ".backup '${snapshot_dir}/${db_name}'"

if [ -d "$state_root" ]; then
  cp -a "$state_root" "${snapshot_dir}/.state"
fi

# Include Caddy's TLS certificate store so a replaced host reuses the existing
# certificate instead of re-requesting one from Let's Encrypt.
if [ -d "$caddy_data_dir" ]; then
  cp -a "$caddy_data_dir" "${snapshot_dir}/caddy-data"
fi

cat >"${snapshot_dir}/metadata.txt" <<METADATA
timestamp=${timestamp}
hostname=${host_name}
image=${image_ref}
database=${db_name}
METADATA

# Timestamped archives live under the archive dir so the S3 lifecycle rule can
# expire them without ever touching the latest copy next to it. Both names come
# from the host env file, which the Terraform lifecycle rule is rendered from.
object_key="${backup_prefix}/${archive_dir}/${host_name}/${timestamp}.tar.gz"
latest_key="${backup_prefix}/${latest_name}"

tar -C "$snapshot_dir" -czf - . | aws s3 cp - "s3://${backup_bucket}/${object_key}" --only-show-errors
# Maintain a stable copy of the most recent archive so a fresh or replaced
# host can restore deterministically on boot. This is a full, independent
# server-side copy, not a reference: expiring the archive it came from does
# not affect it.
aws s3 cp "s3://${backup_bucket}/${object_key}" "s3://${backup_bucket}/${latest_key}" --only-show-errors
